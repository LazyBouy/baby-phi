# Copy this file to .env for local development (never commit .env)
# In GitHub Actions, set these as repository secrets under:
# Settings → Secrets and variables → Actions

# ── LLM Provider Keys (set the one matching config.toml [active].provider) ───

ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
OPENROUTER_API_KEY=sk-or-...

# ── GitHub (only needed locally if you want issue fetching via gh CLI) ────────

GH_TOKEN=ghp_...
