# baby-phi environment overrides — copy to `.env` and fill in.
# `.env` itself is git-ignored; this `.env.example` is the tracked template.

# ── CLI demo (modules/crates/cli) ────────────────────────────────────────
# OpenRouter API key consumed by the phi-core agent loop during
# `cargo run -p cli`. Not required for the HTTP server or web UI.
OPENROUTER_API_KEY=

# ── Server (modules/crates/server) ───────────────────────────────────────
# Selects the config overlay under baby-phi/config/. Values: dev | staging | prod.
BABY_PHI_PROFILE=dev

# Any ServerConfig field can be overridden via BABY_PHI_<SECTION>__<FIELD>.
# Double-underscore (`__`) separates nested keys. Examples:
# BABY_PHI_SERVER__PORT=8080
# BABY_PHI_STORAGE__DATA_DIR=/var/lib/baby-phi/data
# BABY_PHI_TELEMETRY__LOG_FILTER=info,server=debug
# BABY_PHI_TELEMETRY__JSON_LOGS=false

# ── Web (modules/web) ────────────────────────────────────────────────────
# Backend URL the Next.js app proxies /api/v0/* to. Defaults to localhost.
BABY_PHI_API_URL=http://127.0.0.1:8080

# ── Future (do NOT set in M0 — placeholders for visibility) ──────────────
# [M3] OAuth 2.0 (PKCE) client credentials — real auth lands in M3.
# BABY_PHI_AUTH__OIDC__ISSUER=
# BABY_PHI_AUTH__OIDC__CLIENT_ID=
# BABY_PHI_AUTH__OIDC__CLIENT_SECRET=
#
# [M1 / M7b] SurrealDB at-rest encryption master key (AES-256, 32 bytes hex).
# BABY_PHI_STORAGE__ENCRYPTION_KEY=
#
# [M7] Audit log off-site streaming (append-only S3/GCS bucket).
# BABY_PHI_AUDIT__STREAM__BUCKET=
# BABY_PHI_AUDIT__STREAM__REGION=
